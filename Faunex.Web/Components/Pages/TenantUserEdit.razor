@page "/tenant/users/{UserId:guid}/edit"
@rendermode InteractiveServer
@inject Faunex.Web.Api.FaunexApiClient Api
@inject NavigationManager Nav

<PageTitle>Edit Tenant User - Faunex</PageTitle>

<AuthorizeView Roles="TenantAdmin">
    <Authorized Context="tenantUserEditAuth">
        <section class="platform-shell" aria-labelledby="edit-tenant-user-title">
            <div class="platform-header platform-header--compact">
                <div>
                    <p class="platform-kicker">Tenant access</p>
                    <h1 id="edit-tenant-user-title">Edit User</h1>
                    <p>Update this tenant user’s profile, role, and active status.</p>
                </div>

                <a class="btn btn-outline-secondary" href="/tenant/users">Back to users</a>
            </div>

            <section class="platform-panel">
                @if (_isLoading)
                {
                    <p>Loading user...</p>
                }
                else if (_loadError is not null)
                {
                    <div class="alert alert-danger" role="alert">@_loadError</div>
                }
                else
                {
                    <EditForm EditContext="_editContext" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        @if (_saveError is not null)
                        {
                            <div class="alert alert-danger" role="alert">@_saveError</div>
                        }

                        <div class="platform-form-grid">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" @bind-Value="_model.Email" disabled="@_isSaving" />
                                <ValidationMessage For="() => _model.Email" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Display name</label>
                                <InputText class="form-control" @bind-Value="_model.DisplayName" disabled="@_isSaving" />
                                <ValidationMessage For="() => _model.DisplayName" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Role</label>
                                <InputSelect class="form-select" @bind-Value="_model.Role" disabled="@_isSaving">
                                    @foreach (var role in TenantRoles.Assignable)
                                    {
                                        <option value="@role">@GetRoleLabel(role)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => _model.Role" />
                            </div>

                            <div class="mb-3 platform-checkbox">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsActive" disabled="@_isSaving" />
                                <label class="form-check-label">User active</label>
                            </div>
                        </div>

                        <div class="platform-form-actions">
                            <button class="btn btn-primary" type="submit" disabled="@_isSaving">
                                @(_isSaving ? "Saving..." : "Save User")
                            </button>
                            <a class="btn btn-outline-secondary" href="/tenant/users">Cancel</a>
                        </div>
                    </EditForm>
                }
            </section>
        </section>
    </Authorized>
    <NotAuthorized>
        <div class="auth-message">
            <h1>Tenant Access Required</h1>
            <p>Please log in with a tenant administrator account.</p>
            <a class="btn btn-primary" href="/login">Login</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid UserId { get; set; }

    private bool _isLoading;
    private bool _isSaving;
    private string? _loadError;
    private string? _saveError;
    private TenantUserFormModel _model = new();
    private EditContext _editContext = default!;

    protected override async Task OnInitializedAsync()
    {
        _editContext = new EditContext(_model);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var user = await Api.GetAsync<TenantUserDto>($"/api/tenant/users/{UserId}");
            if (user is null)
            {
                _loadError = "User not found.";
                return;
            }

            _model = new TenantUserFormModel
            {
                Email = user.Email,
                DisplayName = user.DisplayName,
                Role = user.Roles.FirstOrDefault() ?? TenantRoles.Buyer,
                IsActive = user.IsActive,
                Password = "Not-used-for-edit"
            };
            _editContext = new EditContext(_model);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_isSaving)
        {
            return;
        }

        _isSaving = true;
        _saveError = null;

        try
        {
            await Api.PutAsync<UpdateTenantUserRequest, TenantUserDto>(
                $"/api/tenant/users/{UserId}",
                new UpdateTenantUserRequest(
                    _model.Email,
                    _model.DisplayName,
                    [_model.Role],
                    _model.IsActive));

            Nav.NavigateTo("/tenant/users?updated=user");
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static string GetRoleLabel(string role) => role switch
    {
        TenantRoles.TenantAdmin => "Tenant admin",
        TenantRoles.Buyer => "Buyer",
        _ => "Seller"
    };
}
