@page "/login"
@rendermode InteractiveServer
@using Faunex.Web.Auth
@inject Faunex.Web.Api.FaunexApiClient Api
@inject Faunex.Web.Auth.TokenStore TokenStore
@inject Faunex.Web.Auth.JwtAuthStateProvider AuthStateProvider
@inject NavigationManager Nav

<h3>Login</h3>

@* .NET 10 Blazor Web App (InteractiveServer) requirement:
   Do not declare EditForm models as nested/private types inside .razor files.
   Component-scoped types can break circuit state serialization and crash during input binding.
   Use a top-level public model type in a shared namespace instead. *@

@* EditForm uses an EditContext created from the single _model instance.
   All inputs must bind to that same _model instance (do not reassign _model after creating _editContext).

   Note: Do not set FormName here. FormName participates in Blazor's enhanced form handling and can cause the browser
   to take over submission (bypassing EditForm's OnValidSubmit) depending on render mode/configuration. *@
<EditForm EditContext="_editContext" OnValidSubmit="LoginAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }

    @if (_success is not null)
    {
        <div class="alert alert-success" role="alert">@_success</div>
    }

    <div class="mb-3">
        <label class="form-label">Email</label>
        @* For InputText, use @bind-Value only. Do not set @bind-Value:event (can crash circuits in InteractiveServer). *@
        <InputText class="form-control" @bind-Value="_model.Email" disabled="@_isSubmitting" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_model.Password" disabled="@_isSubmitting" />
    </div>

    @* Validation/submission is driven only by OnValidSubmit; the button must be type="submit" and have no @onclick handler. *@
    <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">
        @(_isSubmitting ? "Logging in..." : "Login")
    </button>

    <div class="mt-3">
        <a href="/forgot-password">Forgot your password?</a>
    </div>
</EditForm>

@code {
    private bool _isSubmitting;
    private string? _error;
    private string? _success;
    private string? _pendingRedirectTo;

    // Single model instance for the lifetime of the component instance.
    private readonly LoginFormModel _model = new();

    // Single EditContext bound to _model; do not recreate it after the form is rendered.
    private EditContext _editContext = default!;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingRedirectTo is null)
        {
            return Task.CompletedTask;
        }

        var destination = _pendingRedirectTo;
        _pendingRedirectTo = null;
        Nav.NavigateTo(destination);

        return Task.CompletedTask;
    }

    // Match backend DTO contract exactly (Faunex.Api.Auth.LoginRequest).
    private sealed record LoginRequest(string Email, string Password);

    // Match backend DTO contract (Faunex.Api.Auth.AuthResponse) but only bind what we need.
    private sealed record AuthResponse(
        string AccessToken,
        bool IsPlatformAdmin,
        IReadOnlyList<string> Roles);

    private async Task LoginAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _error = null;
        _success = null;
        _isSubmitting = true;

        try
        {
            var response = await Api.PostAsync<LoginRequest, AuthResponse>(
                "/api/auth/login",
                new LoginRequest(_model.Email, _model.Password));

            if (response is null || string.IsNullOrWhiteSpace(response.AccessToken))
            {
                _error = "Login failed.";
                return;
            }

            await TokenStore.SetTokenAsync(response.AccessToken);
            AuthStateProvider.NotifyUserAuthenticationStateChanged();

            _success = "Logged in successfully.";
            var destination = RoleNavigation.IsPlatformUser(response.IsPlatformAdmin, response.Roles)
                ? "/platform"
                : RoleNavigation.IsTenantAdmin(response.Roles)
                    ? "/tenant"
                    : PlatformHostRules.IsPlatformHost(Nav.ToAbsoluteUri(Nav.Uri).Host)
                        ? "/"
                        : "/browse";

            _pendingRedirectTo = destination;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
