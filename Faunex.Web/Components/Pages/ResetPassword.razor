@page "/reset-password"
@rendermode InteractiveServer
@inject Faunex.Web.Api.FaunexApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password - Faunex</PageTitle>

<section class="auth-panel" aria-labelledby="reset-password-title">
    <p class="platform-kicker">Account recovery</p>
    <h1 id="reset-password-title">Choose a new password</h1>

    <EditForm EditContext="_editContext" OnValidSubmit="ResetPasswordAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (_error is not null)
        {
            <div class="alert alert-danger" role="alert">@_error</div>
        }

        @if (_success is not null)
        {
            <div class="alert alert-success" role="status">
                @_success
                <div class="mt-2">
                    <a class="btn btn-primary" href="/login">Login</a>
                </div>
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="_model.Email" disabled="@_isSubmitting" />
        </div>

        <div class="mb-3">
            <label class="form-label">Reset token</label>
            <InputTextArea class="form-control" rows="4" @bind-Value="_model.ResetToken" disabled="@_isSubmitting" />
        </div>

        <div class="mb-3">
            <label class="form-label">New password</label>
            <div class="password-field">
                <InputText class="form-control" type="@(_showNewPassword ? "text" : "password")" @bind-Value="_model.NewPassword" disabled="@_isSubmitting" />
                <button class="btn btn-outline-secondary" type="button" @onclick="() => _showNewPassword = !_showNewPassword" disabled="@_isSubmitting">
                    @(_showNewPassword ? "Hide" : "Show")
                </button>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Confirm password</label>
            <div class="password-field">
                <InputText class="form-control" type="@(_showConfirmPassword ? "text" : "password")" @bind-Value="_model.ConfirmPassword" disabled="@_isSubmitting" />
                <button class="btn btn-outline-secondary" type="button" @onclick="() => _showConfirmPassword = !_showConfirmPassword" disabled="@_isSubmitting">
                    @(_showConfirmPassword ? "Hide" : "Show")
                </button>
            </div>
            <ValidationMessage For="() => _model.ConfirmPassword" />
        </div>

        <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">
            @(_isSubmitting ? "Resetting..." : "Reset password")
        </button>
    </EditForm>
</section>

@code {
    private bool _isSubmitting;
    private bool _showNewPassword;
    private bool _showConfirmPassword;
    private string? _error;
    private string? _success;

    private ResetPasswordFormModel _model = new();
    private EditContext _editContext = default!;

    [SupplyParameterFromQuery(Name = "email")]
    private string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    private string? Token { get; set; }

    protected override void OnInitialized()
    {
        _model = new ResetPasswordFormModel
        {
            Email = Email ?? string.Empty,
            ResetToken = Token ?? string.Empty
        };

        _editContext = new EditContext(_model);
    }

    private sealed record ResetPasswordRequest(string Email, string ResetToken, string NewPassword);

    private async Task ResetPasswordAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _error = null;
        _success = null;
        _isSubmitting = true;

        try
        {
            await Api.PostAsync(
                "/api/auth/reset-password",
                new ResetPasswordRequest(_model.Email, _model.ResetToken, _model.NewPassword));

            _success = "Your password has been reset.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
