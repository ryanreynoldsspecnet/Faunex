@page "/platform"
@rendermode InteractiveServer
@inject Faunex.Web.Api.FaunexApiClient Api

<PageTitle>Platform Admin - Faunex</PageTitle>

<AuthorizeView Roles="PlatformAdmin,PlatformSuperAdmin">
    <Authorized Context="platformAuth">
        <section class="platform-shell" aria-labelledby="platform-title">
            <div class="platform-header">
                <div>
                    <p class="platform-kicker">Faunex control centre</p>
                    <h1 id="platform-title">Tenants</h1>
                    <p>Search, onboard, and manage the tenant marketplaces running on the Faunex platform.</p>
                </div>

                <a class="btn btn-primary" href="/platform/tenants/new">Add Tenant</a>
            </div>

            <div class="platform-metrics" aria-label="Platform metrics">
                <article>
                    <span>Tenants</span>
                    <strong>@(_tenants.Count)</strong>
                </article>
                <article>
                    <span>Active</span>
                    <strong>@(_tenants.Count(x => x.IsActive))</strong>
                </article>
                <article>
                    <span>Domains</span>
                    <strong>@(_tenants.Sum(x => x.DomainCount))</strong>
                </article>
            </div>

            <section class="platform-panel" aria-labelledby="tenants-title">
                <div class="platform-panel__header">
                    <div>
                        <p class="platform-kicker">Tenant registry</p>
                        <h2 id="tenants-title">Tenant List</h2>
                    </div>

                    <button class="btn btn-outline-secondary" type="button" @onclick="LoadTenantsAsync" disabled="@_isLoading">
                        @(_isLoading ? "Refreshing..." : "Refresh")
                    </button>
                </div>

                <div class="platform-list-toolbar">
                    <div>
                        <label class="form-label" for="tenant-search">Search tenants</label>
                        <InputText id="tenant-search" class="form-control" placeholder="Search name, contact, phone, domain..." @bind-Value="_search" @bind-Value:event="oninput" />
                    </div>

                    <a class="btn btn-primary" href="/platform/tenants/new">Add Tenant</a>
                </div>

                @if (_isLoading)
                {
                    <p>Loading tenants...</p>
                }
                else if (_loadError is not null)
                {
                    <div class="alert alert-danger" role="alert">@_loadError</div>
                }
                else if (FilteredTenants.Count == 0)
                {
                    <div class="platform-empty">
                        <strong>No tenants found.</strong>
                        <p>Create the first tenant or adjust the search.</p>
                    </div>
                }
                else
                {
                    <div class="platform-table-wrap">
                        <table class="table platform-table">
                            <thead>
                                <tr>
                                    <th>Tenant</th>
                                    <th>Main contact</th>
                                    <th>Telephone</th>
                                    <th>Primary domain</th>
                                    <th>Status</th>
                                    <th class="platform-table__actions">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tenant in FilteredTenants)
                                {
                                    <tr>
                                        <td>
                                            <strong>@tenant.Name</strong>
                                            <span>@(tenant.CompanyName ?? "No company captured")</span>
                                        </td>
                                        <td>
                                            @GetContactName(tenant)
                                            @if (!string.IsNullOrWhiteSpace(tenant.ContactEmail))
                                            {
                                                <span>@tenant.ContactEmail</span>
                                            }
                                        </td>
                                        <td>@(tenant.ContactPhone ?? "-")</td>
                                        <td>
                                            @(tenant.PrimaryDomain ?? "-")
                                            <span>@tenant.DomainCount active domain@(tenant.DomainCount == 1 ? string.Empty : "s")</span>
                                        </td>
                                        <td>
                                            <span class="platform-status @(tenant.IsActive ? "platform-status--active" : "platform-status--inactive")">
                                                @(tenant.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td class="platform-row-actions">
                                            <a class="btn btn-sm btn-outline-secondary" href="@($"/platform/users?tenantId={tenant.Id}")">Users</a>
                                            <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Edit</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </section>
    </Authorized>
    <NotAuthorized>
        <div class="auth-message">
            <h1>Platform Access Required</h1>
            <p>Please log in with a Faunex platform administrator account.</p>
            <a class="btn btn-primary" href="/login">Login</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _isLoading;
    private string? _loadError;
    private string? _search;
    private List<TenantDto> _tenants = [];

    private IReadOnlyList<TenantDto> FilteredTenants
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_search))
            {
                return _tenants;
            }

            var term = _search.Trim();
            return _tenants
                .Where(x =>
                    Contains(x.Name, term)
                    || Contains(x.CompanyName, term)
                    || Contains(GetContactName(x), term)
                    || Contains(x.ContactEmail, term)
                    || Contains(x.ContactPhone, term)
                    || Contains(x.PrimaryDomain, term)
                    || Contains(x.VatNumber, term)
                    || Contains(x.RegistrationNumber, term))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _tenants = await Api.GetAsync<List<TenantDto>>("/api/platform/tenants") ?? [];
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetContactName(TenantDto tenant)
    {
        var name = string.Join(" ", new[] { tenant.ContactFirstName, tenant.ContactLastName }.Where(x => !string.IsNullOrWhiteSpace(x)));
        return string.IsNullOrWhiteSpace(name) ? "-" : name;
    }

    private static bool Contains(string? value, string term) =>
        value?.Contains(term, StringComparison.OrdinalIgnoreCase) == true;
}
