@page "/browse"
@inject Faunex.Web.Api.FaunexApiClient Api
@inject NavigationManager Nav

<h3>Browse Listings</h3>

@if (_isPlatformHost)
{
    <div class="alert alert-info" role="status">
        Listings are shown on tenant marketplace domains. Faunex is the platform workspace for tenant setup and administration.
    </div>

    <a class="btn btn-primary" href="/login">Platform Login</a>
}
else if (_isLoading)
{
    <p>Loading listings...</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
else if (_items is null || _items.Count == 0)
{
    <div class="alert alert-info" role="alert">No listings available</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Price</th>
                <th>Type</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>
                        <NavLink href="@($"/listings/{item.Id}")">@item.Title</NavLink>
                    </td>
                    <td>@FormatPrice(item)</td>
                    <td>@GetSaleType(item)</td>
                    <td>
                        @if (!item.BuyNowPrice.HasValue)
                        {
                            <NavLink class="btn btn-outline-primary btn-sm" href="@($"/auctions/{item.Id}")">View auction</NavLink>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _isLoading;
    private bool _isPlatformHost;
    private string _host = string.Empty;
    private string? _error;
    private IReadOnlyList<Faunex.Application.DTOs.ListingDto>? _items;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _host = Nav.ToAbsoluteUri(Nav.Uri).Host;
        _isPlatformHost = PlatformHostRules.IsPlatformHost(_host);
        if (_isPlatformHost)
        {
            return;
        }

        _isLoading = true;
        _error = null;
        _items = null;

        try
        {
            var host = MarketplaceRoutes.HostQuery(_host);
            _items = await Api.GetAsync<IReadOnlyList<Faunex.Application.DTOs.ListingDto>>($"/api/marketplace/listings?host={host}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatPrice(Faunex.Application.DTOs.ListingDto item)
    {
        var price = item.BuyNowPrice ?? item.StartingPrice;
        return $"{price:0.##} {item.CurrencyCode}";
    }

    private static string GetSaleType(Faunex.Application.DTOs.ListingDto item)
    {
        return item.BuyNowPrice.HasValue ? "Fixed" : "Auction";
    }
}
