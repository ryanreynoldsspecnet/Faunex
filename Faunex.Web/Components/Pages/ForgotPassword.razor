@page "/forgot-password"
@rendermode InteractiveServer
@inject Faunex.Web.Api.FaunexApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password - Faunex</PageTitle>

<section class="auth-panel" aria-labelledby="forgot-password-title">
    <p class="platform-kicker">Account recovery</p>
    <h1 id="forgot-password-title">Reset your password</h1>
    <p>Enter your account email address and we will prepare a password reset.</p>

    <EditForm EditContext="_editContext" OnValidSubmit="RequestResetAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (_error is not null)
        {
            <div class="alert alert-danger" role="alert">@_error</div>
        }

        @if (_message is not null)
        {
            <div class="alert alert-success" role="status">@_message</div>
        }

        @if (_devResetToken is not null)
        {
            <div class="alert alert-warning" role="status">
                <strong>Development reset token</strong>
                <textarea class="form-control mt-2" rows="4" readonly>@_devResetToken</textarea>
                <a class="btn btn-primary mt-2" href="@BuildResetUrl()">Continue to reset password</a>
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="_model.Email" disabled="@_isSubmitting" />
        </div>

        <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">
            @(_isSubmitting ? "Sending..." : "Send reset instructions")
        </button>
    </EditForm>
</section>

@code {
    private bool _isSubmitting;
    private string? _error;
    private string? _message;
    private string? _devResetToken;

    private readonly ForgotPasswordFormModel _model = new();
    private EditContext _editContext = default!;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    private sealed record ForgotPasswordRequest(string Email);
    private sealed record ForgotPasswordResponse(string Message, string? ResetToken);

    private async Task RequestResetAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _error = null;
        _message = null;
        _devResetToken = null;
        _isSubmitting = true;

        try
        {
            var response = await Api.PostAsync<ForgotPasswordRequest, ForgotPasswordResponse>(
                "/api/auth/forgot-password",
                new ForgotPasswordRequest(_model.Email));

            _message = response?.Message ?? "If that account exists, password reset instructions will be sent.";
            _devResetToken = string.IsNullOrWhiteSpace(response?.ResetToken) ? null : response.ResetToken;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string BuildResetUrl()
    {
        var email = Uri.EscapeDataString(_model.Email);
        var token = Uri.EscapeDataString(_devResetToken ?? string.Empty);
        return $"/reset-password?email={email}&token={token}";
    }
}
